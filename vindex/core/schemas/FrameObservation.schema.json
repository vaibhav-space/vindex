{
  "description": "Observation representing a sampled keyframe.",
  "properties": {
    "observation_id": {
      "default": "",
      "description": "Unique identifier for this observation",
      "title": "Observation Id",
      "type": "string"
    },
    "schema_version": {
      "default": "2.0",
      "description": "Schema version of this observation",
      "title": "Schema Version",
      "type": "string"
    },
    "timestamp_ms": {
      "description": "Timestamp in milliseconds from start of video",
      "title": "Timestamp Ms",
      "type": "integer"
    },
    "duration_ms": {
      "default": 0,
      "description": "Duration in milliseconds of this observation",
      "title": "Duration Ms",
      "type": "integer"
    },
    "source": {
      "default": "",
      "description": "The source/extractor that generated this observation (v1.0 compat)",
      "title": "Source",
      "type": "string"
    },
    "source_module": {
      "default": "",
      "description": "The perception module that generated this observation",
      "title": "Source Module",
      "type": "string"
    },
    "runtime_name": {
      "default": "",
      "description": "The runtime engine name",
      "title": "Runtime Name",
      "type": "string"
    },
    "runtime_version": {
      "default": "",
      "description": "The runtime engine version",
      "title": "Runtime Version",
      "type": "string"
    },
    "model_name": {
      "default": "",
      "description": "The model name",
      "title": "Model Name",
      "type": "string"
    },
    "model_version": {
      "default": "",
      "description": "The model version",
      "title": "Model Version",
      "type": "string"
    },
    "processing_time_ms": {
      "default": 0,
      "description": "Inference time in milliseconds",
      "title": "Processing Time Ms",
      "type": "integer"
    },
    "confidence": {
      "default": 1.0,
      "description": "Confidence score between 0.0 and 1.0",
      "title": "Confidence",
      "type": "number"
    },
    "observation_type": {
      "const": "frame",
      "default": "frame",
      "title": "Observation Type",
      "type": "string"
    },
    "bbox": {
      "anyOf": [
        {
          "items": {
            "type": "number"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Normalized bounding box [x, y, w, h]",
      "title": "Bbox"
    },
    "polygon": {
      "anyOf": [
        {
          "items": {
            "items": {
              "type": "number"
            },
            "type": "array"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Corner points [[x, y], ...]",
      "title": "Polygon"
    },
    "coordinate_system": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Coordinate system type (e.g., 'normalized')",
      "title": "Coordinate System"
    },
    "region_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Target region ID",
      "title": "Region Id"
    },
    "image_reference": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Path or reference to image file",
      "title": "Image Reference"
    },
    "frame_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Reference to frame path or ID",
      "title": "Frame Ref"
    },
    "shot_id": {
      "description": "The shot this keyframe belongs to",
      "title": "Shot Id",
      "type": "string"
    },
    "scene_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Reference to scene ID",
      "title": "Scene Id"
    },
    "frame_path": {
      "description": "Local path to the saved keyframe image file",
      "title": "Frame Path",
      "type": "string"
    },
    "frame_hash": {
      "description": "SHA-256 hash of the frame image contents",
      "title": "Frame Hash",
      "type": "string"
    }
  },
  "required": [
    "timestamp_ms",
    "shot_id",
    "frame_path",
    "frame_hash"
  ],
  "title": "FrameObservation",
  "type": "object"
}