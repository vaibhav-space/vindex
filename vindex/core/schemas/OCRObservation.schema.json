{
  "description": "Observation representing text detected on screen.",
  "properties": {
    "observation_id": {
      "default": "",
      "description": "Unique identifier for this observation",
      "title": "Observation Id",
      "type": "string"
    },
    "schema_version": {
      "default": "2.0",
      "description": "Schema version of this observation",
      "title": "Schema Version",
      "type": "string"
    },
    "timestamp_ms": {
      "description": "Timestamp in milliseconds from start of video",
      "title": "Timestamp Ms",
      "type": "integer"
    },
    "duration_ms": {
      "default": 0,
      "description": "Duration in milliseconds of this observation",
      "title": "Duration Ms",
      "type": "integer"
    },
    "source": {
      "default": "",
      "description": "The source/extractor that generated this observation (v1.0 compat)",
      "title": "Source",
      "type": "string"
    },
    "source_module": {
      "default": "",
      "description": "The perception module that generated this observation",
      "title": "Source Module",
      "type": "string"
    },
    "runtime_name": {
      "default": "",
      "description": "The runtime engine name",
      "title": "Runtime Name",
      "type": "string"
    },
    "runtime_version": {
      "default": "",
      "description": "The runtime engine version",
      "title": "Runtime Version",
      "type": "string"
    },
    "model_name": {
      "default": "",
      "description": "The model name",
      "title": "Model Name",
      "type": "string"
    },
    "model_version": {
      "default": "",
      "description": "The model version",
      "title": "Model Version",
      "type": "string"
    },
    "processing_time_ms": {
      "default": 0,
      "description": "Inference time in milliseconds",
      "title": "Processing Time Ms",
      "type": "integer"
    },
    "confidence": {
      "default": 1.0,
      "description": "OCR confidence score between 0.0 and 1.0",
      "title": "Confidence",
      "type": "number"
    },
    "observation_type": {
      "const": "ocr",
      "default": "ocr",
      "title": "Observation Type",
      "type": "string"
    },
    "bbox": {
      "description": "Bounding box coordinates in format [x, y, w, h]",
      "items": {
        "type": "number"
      },
      "title": "Bbox",
      "type": "array"
    },
    "polygon": {
      "anyOf": [
        {
          "items": {
            "items": {
              "type": "number"
            },
            "type": "array"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Corner points [[x, y], ...]",
      "title": "Polygon"
    },
    "coordinate_system": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Coordinate system type (e.g., 'normalized')",
      "title": "Coordinate System"
    },
    "region_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Target region ID",
      "title": "Region Id"
    },
    "image_reference": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Path or reference to image file",
      "title": "Image Reference"
    },
    "frame_ref": {
      "description": "Path or ID of the frame this OCR text was found in",
      "title": "Frame Ref",
      "type": "string"
    },
    "shot_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Reference to shot ID",
      "title": "Shot Id"
    },
    "scene_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Reference to scene ID",
      "title": "Scene Id"
    },
    "text": {
      "description": "Transcribed screen text",
      "title": "Text",
      "type": "string"
    }
  },
  "required": [
    "timestamp_ms",
    "bbox",
    "frame_ref",
    "text"
  ],
  "title": "OCRObservation",
  "type": "object"
}